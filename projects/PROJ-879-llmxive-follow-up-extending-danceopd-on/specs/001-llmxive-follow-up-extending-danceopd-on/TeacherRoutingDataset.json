{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://llmxive.org/schemas/TeacherRoutingDataset.json",
  "title": "TeacherRoutingDataset",
  "description": "Schema for the dataset generated by running the DanceOPD teacher model. Contains prompt embeddings, noise levels, routing labels, and velocity vectors.",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "source_imagenet": { "type": "string" },
        "source_laion": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "teacher_model_hash": { "type": "string" },
        "total_samples": { "type": "integer" }
      },
      "required": ["version", "generated_at", "total_samples"]
    },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sample_id": { "type": "string" },
          "source": { "type": "string", "enum": ["imagenet", "laion"] },
          "prompt_embedding": {
            "type": "array",
            "items": { "type": "number" },
            "description": "Flattened embedding vector from the text encoder"
          },
          "noise_level": { "type": "number", "minimum": 0, "maximum": 1 },
          "routing_label": { "type": "string", "description": "Expert field ID selected by the teacher" },
          "velocity_vector": {
            "type": "array",
            "items": { "type": "number" },
            "description": "Velocity vector output by the selected expert field"
          },
          "undefined_route": { "type": "boolean", "default": false }
        },
        "required": ["sample_id", "source", "prompt_embedding", "noise_level", "routing_label", "velocity_vector"]
      }
    }
  },
  "required": ["metadata", "data"]
}
