{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://llmxive.org/schemas/DecisionTreeMetadata.json",
  "title": "DecisionTreeMetadata",
  "description": "Schema for metadata describing a trained Decision Tree model used for routing approximation.",
  "type": "object",
  "properties": {
    "model_id": { "type": "string" },
    "max_depth": { "type": "integer", "minimum": 2, "maximum": 20 },
    "training_split_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
    "trained_at": { "type": "string", "format": "date-time" },
    "dataset_hash": { "type": "string" },
    "metrics": {
      "type": "object",
      "properties": {
        "train_accuracy": { "type": "number" },
        "test_accuracy": { "type": "number" },
        "routing_consistency": { "type": "number" }
      },
      "required": ["train_accuracy", "test_accuracy"]
    },
    "feature_names": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of feature names used for training (e.g., 'prompt_embedding_dim_0', 'noise_level')"
    },
    "class_names": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of unique expert IDs observed in the training data"
    },
    "model_path": { "type": "string", "description": "Relative path to the saved model file (e.g., .pkl)" }
  },
  "required": ["model_id", "max_depth", "trained_at", "metrics", "feature_names", "model_path"]
}