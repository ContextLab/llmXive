\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{ziplab-tech-report}[2026/04/24 ZIP Lab technical report style]

% --------------------------------------------------
% Packages
% --------------------------------------------------
\RequirePackage[a4paper,top=2.2cm,bottom=2.4cm,left=2.4cm,right=2.4cm,headheight=14pt,headsep=16pt,footskip=26pt]{geometry}
\RequirePackage[T1]{fontenc}
\RequirePackage{lmodern}
\RequirePackage{microtype}
\RequirePackage{placeins}
\RequirePackage{hyphenat}
\RequirePackage{setspace}
\RequirePackage[table]{xcolor}
\RequirePackage{tgheros}
\RequirePackage[most]{tcolorbox}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}
\RequirePackage{caption}
\RequirePackage[numbers,sort&compress]{natbib}
\RequirePackage{graphicx}

% --------------------------------------------------
% Color System (MODERN + CLEAN)
% --------------------------------------------------
\definecolor{ziplabblue}{HTML}{2563EB}     % primary (modern blue)
\definecolor{ziplabaccent}{HTML}{F59E0B}   % accent (orange highlight)
\definecolor{ziplabdark}{HTML}{0F172A}     % main text (deep slate)
\definecolor{ziplabgray}{HTML}{475569}     % secondary text
\definecolor{ziplabline}{HTML}{CBD5E1}     % divider
\definecolor{ziplabcard}{HTML}{F1F5F9}     % light background

% --------------------------------------------------
% Meta
% --------------------------------------------------
\newcommand{\ziplabreportlabel}{ZIP Lab}
\newcommand{\ziplabreportshorttitle}{}
\newcommand{\techreportlabel}[1]{\renewcommand{\ziplabreportlabel}{#1}}
\newcommand{\techreportshorttitle}[1]{\renewcommand{\ziplabreportshorttitle}{#1}}

% --------------------------------------------------
% Typography
% --------------------------------------------------
\newcommand{\ziplabsans}{\fontfamily{qhv}\selectfont}
\newcommand{\ziplabtitlefont}{\ziplabsans\bfseries}
\newcommand{\ziplabdatefont}{\rmfamily\itshape}

\newcommand{\ziplabmetalabel}[1]{{\ziplabsans\small\bfseries\color{ziplabblue} #1:}\hspace{0.35em}}

\newcommand{\ziplabbrandmark}{}

% --------------------------------------------------
% Paragraph & spacing
% --------------------------------------------------
\setlength{\parindent}{1em}
\setlength{\parskip}{0pt}
\linespread{1.05} % 更舒服

% --------------------------------------------------
% Caption Style
% --------------------------------------------------
\DeclareCaptionLabelSeparator{custom}{}
\DeclareCaptionFormat{custom}{{\ziplabsans\textbf{#1 #2}} #3}
\captionsetup{
  singlelinecheck=false,
  format=custom,
  labelsep=custom,
  font=small
}

% --------------------------------------------------
% Section Style (More hierarchy)
% --------------------------------------------------
\titleformat*{\section}{\Large\ziplabsans\bfseries\color{ziplabdark}}
\titleformat*{\subsection}{\large\ziplabsans\bfseries\color{ziplabdark}}
\titleformat*{\subsubsection}{\normalsize\ziplabsans\bfseries\color{ziplabdark}}

\titlespacing*{\section}{0pt}{1.2em}{0.6em}
\titlespacing*{\subsection}{0pt}{0.9em}{0.4em}

% --------------------------------------------------
% Abstract
% --------------------------------------------------
\renewenvironment{abstract}
  {%
    \par\noindent
    \small
    \color{ziplabdark}
  }
  {%
    \par\normalsize
  }

% --------------------------------------------------
% Header / Footer
% --------------------------------------------------
\fancypagestyle{firstheader}{
  \fancyhf{}
  \fancyhead[L]{\footnotesize\ziplabsans\color{ziplabgray}\ziplabreportlabel}
  \fancyhead[R]{\ziplabbrandmark}
  \renewcommand{\headrulewidth}{0.8pt}
  \renewcommand{\headrule}{\hbox to\headwidth{\color{ziplabline}\leaders\hrule height \headrulewidth\hfill}}
}

\pagestyle{fancy}
\fancyhf{}
\fancyfoot[C]{\footnotesize\ziplabsans\color{ziplabgray}\thepage}
\renewcommand{\headrulewidth}{0pt}

% --------------------------------------------------
% Title Box (KEY VISUAL UPGRADE)
% --------------------------------------------------
\newtcolorbox{ziplabtitlebox}{
  enhanced,
  frame hidden,
  colback=ziplabcard,
  colframe=ziplabline,
  boxrule=0.5pt,
  arc=8pt,
  left=0.34cm,
  right=0.34cm,
  top=0.28cm,
  bottom=0.28cm,
  before skip=0pt,
  after skip=1.0em,
  drop shadow={opacity=0.06}
}

% --------------------------------------------------
% Highlight command (NEW)
% --------------------------------------------------
\newcommand{\highlight}[1]{\textcolor{ziplabaccent}{\textbf{#1}}}

% --------------------------------------------------
% Subtle divider
% --------------------------------------------------
\newcommand{\ziplabdivider}{
  \vspace{0.6em}
  {\color{ziplabline}\hrule height 0.6pt}
  \vspace{0.6em}
}
