[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .venv,
    data/,
    data/raw/,
    data/processed/,
    data/metrics/,
    results/,
    state/
per-file-ignores =
    code/__init__.py:F401
ignore = E203, W503
max-complexity = 10
count = True
show-source = True
statistics = True