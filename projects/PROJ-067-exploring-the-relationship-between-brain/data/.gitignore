# Ignore large data files
*.nii
*.nii.gz
*.img
*.hdr
*.bval
*.bvec

# Ignore processed data
processed/*
!processed/.gitkeep

# Ignore raw data
raw/*
!raw/.gitkeep

# Ignore metrics
metrics/*
!metrics/.gitkeep

# Ignore atlas files
atlas/*
!atlas/.gitkeep

# Ignore temporary files
*.tmp
*.temp
*.cache

# Ignore large binary files
*.mat
*.h5
*.hdf5

# Ignore OpenNeuro downloads
ds000228/

# Ignore generated datasets
*.parquet
*.feather
