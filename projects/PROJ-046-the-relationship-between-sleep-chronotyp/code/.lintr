# T031 Lintr Configuration
# This file configures the lintr package to enforce cyclomatic complexity < 10
# and checks for unused imports.

linters:
  - cyclocomp_linter(limit = 10)
  - unused_import_linter()
  - object_usage_linter()
  - whitespace_linter()
  - trailing_whitespace_linter()
  - trailing_blank_lines_linter()
