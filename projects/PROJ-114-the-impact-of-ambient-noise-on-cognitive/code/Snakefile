# T018: Preprocess rule
rule preprocess:
    input:
        RAW_INPUT
    output:
        os.path.join(PROCESSED_DATA_DIR, "analysis_dataset.parquet")
    run:
        if not os.path.exists(input[0]):
            raise FileNotFoundError(f"Raw input file not found: {input[0]}. Please ensure data acquisition (T041/T042) has run or synthetic data is generated.")
        
        logger = logging.getLogger(__name__)
        logger.info(f"Starting preprocessing pipeline on {input[0]}")
        
        try:
            df = pd.read_csv(input[0])
            
            # Apply pipeline steps
            df_filtered = filter_participants(df)
            df_normalized = normalize_reaction_times(df_filtered)
            df_aggregated = aggregate_noise_logs(df_normalized)
            df_final = create_noise_bins(df_aggregated)
            
            # Save output
            df_final.to_parquet(output[0], index=False)
            logger.info(f"Preprocessing complete. Saved to {output[0]}")
            
        except Exception as e:
            logger.error(f"Preprocessing failed: {str(e)}")
            raise

