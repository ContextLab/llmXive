# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Data artifacts (tracked via git-lfs or external storage in real scenario)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/results/*
!data/results/.gitkeep

# Logs and temporary files
logs/
*.log
*.tmp

# OS files
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Snakestate
.snakestate.yaml
state.yaml
