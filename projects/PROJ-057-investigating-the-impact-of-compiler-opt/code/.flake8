[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    .hg,
    .mypy_cache,
    .tox,
    .venv,
    _build,
    buck-out,
    build,
    dist,
    __pycache__,
    *.pyc
per-file-ignores =
    # Allow unused imports in __init__.py files for public API exposure
    */__init__.py: F401
    # Allow unused arguments in function signatures (e.g., for callbacks or abstract methods)
    code/benchmarks/config.py: ARG001
    code/analysis/stats.py: ARG001
max-complexity = 10
count = True
show-source = True
statistics = True
