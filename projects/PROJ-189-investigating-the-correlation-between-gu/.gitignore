# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
.env/

# Large data files (raw and processed)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/models/*
!data/models/.gitkeep

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db

# Logs and temporary files
*.log
tmp/
.tmp/

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Coverage and test artifacts
.coverage
htmlcov/
.pytest_cache/

# Secrets and credentials
*.pem
*.key
secrets.json
.env.local