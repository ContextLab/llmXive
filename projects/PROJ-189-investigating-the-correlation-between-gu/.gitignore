# Large data files
data/raw/*
!data/raw/.gitkeep

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
.env/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Jupyter notebooks
.ipynb_checkpoints/

# Temporary files
tmp/
temp/

# Data models and processed files (keep raw, exclude intermediate)
data/models/*
data/processed/*
!data/processed/.gitkeep
!data/models/.gitkeep