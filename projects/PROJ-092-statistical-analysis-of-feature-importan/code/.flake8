[flake8]
max-line-length = 88
extend-ignore = E203, E266, W503
exclude = .git,__pycache__,build,dist,venv,env,.venv
per-file-ignores =
    # Allow unused imports in __init__.py if present (not currently used but good practice)
    */__init__.py: F401
    # Test files can have unused fixtures
    tests/*: F811
