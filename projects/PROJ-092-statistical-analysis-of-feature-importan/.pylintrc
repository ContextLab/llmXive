[MAIN]
ignore=tests,build,dist,.eggs,*.egg-info

[MESSAGES CONTROL]
disable=
    C0114,
    C0115,
    C0116,
    R0903,
    R0913,
    R0914,
    W0511

[FORMAT]
max-line-length=88
max-module-lines=1000

[DESIGN]
max-args=10
max-locals=20
max-returns=6
max-branches=20
max-statements=100
max-attributes=15
max-public-methods=20

[TYPECHECK]
ignored-modules=numpy,pandas
