# Global configuration
config = {
    "cores": int(os.getenv("SNAKE_CORES", 1)),
    "ram_limit_gb": 7.0,
    "log_level": "INFO",
}

# Initialize paths
ensure_paths()

# Rule: verify_data_availability
# This rule runs before 'download' to ensure at least one valid source exists.
# It imports logic from code/download.py to attempt source verification without downloading full files.
rule verify_data_availability:
    message: "Verifying data availability for required accessions..."
    input:
        # Dummy input to force execution order; actual check is in the shell command
        check_marker = "data/.check_availability"
    output:
        touch("data/.availability_verified")
    run:
        import logging
        from download import verify_source_availability
        
        logging.basicConfig(level=logging.INFO)
        logger = logging.getLogger(__name__)
        
        accessions = get_all_accessions()
        logger.info(f"Checking availability for accessions: {accessions}")
        
        available = []
        for acc in accessions:
            if verify_source_availability(acc):
                available.append(acc)
            else:
                logger.warning(f"No valid raw count source found for {acc}")
        
        if not available:
            logger.error("CRITICAL: No valid raw count sources found for any required accessions. Aborting workflow.")
            logger.error("Please verify GEO accessions or network connectivity.")
            sys.exit(1)
        
        logger.info(f"Data verification successful. Available accessions: {available}")
        # Write available list to a temp file for downstream rules if needed
        with open("data/available_accessions.txt", "w") as f:
            for acc in available:
                f.write(f"{acc}\n")

# Rule: download
rule download:
    input:
        "data/.availability_verified"
    output:
        lambda wildcards: f"data/raw/{wildcards.accession}_counts.h5ad"
    message: "Downloading raw count matrix for {wildcards.accession}"
    run:
        from download import download_accession as dl_func
        acc = wildcards.accession
        dl_func(acc)

# Rule: preprocess
rule preprocess:
    input:
        "data/raw/{accession}_counts.h5ad"
    output:
        "data/processed/{accession}_processed.h5ad"
    message: "Preprocessing {wildcards.accession}: QC and HVG selection"
    run:
        from preprocess import preprocess_accession as pp_func
        acc = wildcards.accession
        pp_func(acc)

# Rule: geometry (computed on raw space as per spec)
