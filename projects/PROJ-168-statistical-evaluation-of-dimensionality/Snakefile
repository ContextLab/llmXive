# Rule: embeddings
rule embeddings:
    input:
        "data/processed/{accession}_processed.h5ad"
    output:
        "results/embeddings/{accession}_embeddings.h5ad"
    message: "Generating embeddings for {wildcards.accession}"
    run:
        from embeddings import run_embedding_pipeline as emb_func
        acc = wildcards.accession
        emb_func(acc)

# Rule: cluster
rule cluster:
    input:
        "results/embeddings/{accession}_embeddings.h5ad"
    output:
        "results/clustering/{accession}_clusters.json"
    message: "Clustering embeddings for {wildcards.accession}"
    run:
        from clustering import process_accession as cluster_func
        acc = wildcards.accession
        cluster_func(acc)

# Rule: fidelity
