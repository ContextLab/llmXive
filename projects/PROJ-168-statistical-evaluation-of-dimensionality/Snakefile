# Snakemake workflow for Statistical Evaluation of Dimensionality Reduction
# on Gene Expression Data
#
# Rules: download, preprocess, embeddings, geometry, cluster, fidelity, stats

import os
import sys
from pathlib import Path

# Add code directory to path for imports
code_dir = Path("code").resolve()
if str(code_dir) not in sys.path:
    sys.path.insert(0, str(code_dir))

from config import Config
from utils import get_resource_monitor

config = Config()

# Global resources
_resources = {
    "mem_mb": 7000,  # 7GB limit per rule as per CI constraints
    "time": 3600,    # 1 hour default timeout
    "threads": 4
}

# Input/Output directories
RAW_DIR = config.DATA_RAW
PROCESSED_DIR = config.DATA_PROCESSED
RESULTS_DIR = config.RESULTS
FIGURES_DIR = config.FIGURES

# Ensure directories exist
for d in [RAW_DIR, PROCESSED_DIR, RESULTS_DIR, FIGURES_DIR]:
    d.mkdir(parents=True, exist_ok=True)

# Accession list from config
ACCESSIONS = config.DATASET_ACCESSIONS

# --------------------------------------------------------------------------
# Rule: download
# Fetches raw count matrices for specified GEO accessions
# --------------------------------------------------------------------------
rule download:
    input:
        lambda wildcards: config.get_raw_path(wildcards.accession)
    output:
        raw=config.get_raw_path("{accession}", ext=".h5ad"),
        meta=config.get_raw_path("{accession}", ext=".json")
    resources:
        _resources
    log:
        "results/logs/download_{accession}.log"
    shell:
        """
        python code/download.py \
            --accession {wildcards.accession} \
            --output-dir {RAW_DIR} \
            --log {log}
        """

# --------------------------------------------------------------------------
# Rule: preprocess
# Applies QC, HVG selection, and deterministic sampling
# --------------------------------------------------------------------------
rule preprocess:
    input:
        raw=lambda wildcards: config.get_raw_path(wildcards.accession, ext=".h5ad")
    output:
        processed=config.get_processed_path("{accession}", ext=".h5ad"),
        hvg_list=config.get_processed_path("{accession}", ext="_hvg.txt")
    resources:
        _resources
    log:
        "results/logs/preprocess_{accession}.log"
    shell:
        """
        python code/preprocess.py \
            --input {input.raw} \
            --output {output.processed} \
            --hvg-list {output.hvg_list} \
            --log {log}
        """

# --------------------------------------------------------------------------
# Rule: embeddings
# Generates PCA, t-SNE, and UMAP embeddings
# --------------------------------------------------------------------------
rule embeddings:
    input:
        processed=config.get_processed_path("{accession}", ext=".h5ad")
    output:
        pca=config.get_processed_path("{accession}", ext="_pca.h5ad"),
        tsne=config.get_processed_path("{accession}", ext="_tsne.h5ad"),
        umap=config.get_processed_path("{accession}", ext="_umap.h5ad")
    resources:
        _resources
    log:
        "results/logs/embeddings_{accession}.log"
    shell:
        """
        python code/embeddings.py \
            --input {input.processed} \
            --output-pca {output.pca} \
            --output-tsne {output.tsne} \
            --output-umap {output.umap} \
            --log {log}
        """

# --------------------------------------------------------------------------
# Rule: geometry
# Computes Global Linearity (Trustworthiness) and Local Continuity (LCA)
# --------------------------------------------------------------------------
rule geometry:
    input:
        processed=config.get_processed_path("{accession}", ext=".h5ad"),
        pca=config.get_processed_path("{accession}", ext="_pca.h5ad")
    output:
        metrics=config.get_results_path("{accession}", ext="_geometry.csv")
    resources:
        _resources
    log:
        "results/logs/geometry_{accession}.log"
    shell:
        """
        python code/geometry.py \
            --input {input.processed} \
            --pca {input.pca} \
            --output {output.metrics} \
            --log {log}
        """

# --------------------------------------------------------------------------
# Rule: cluster
# Applies Leiden clustering with resolution optimization
# --------------------------------------------------------------------------
rule cluster:
    input:
        umap=config.get_processed_path("{accession}", ext="_umap.h5ad")
    output:
        clustered=config.get_processed_path("{accession}", ext="_clustered.h5ad"),
        report=config.get_results_path("{accession}", ext="_clustering.json")
    resources:
        _resources
    log:
        "results/logs/cluster_{accession}.log"
    shell:
        """
        python code/clustering.py \
            --input {input.umap} \
            --output {output.clustered} \
            --report {output.report} \
            --log {log}
        """

# --------------------------------------------------------------------------
# Rule: fidelity
# Calculates ARI and NMI against ground-truth labels
# --------------------------------------------------------------------------
rule fidelity:
    input:
        clustered=config.get_processed_path("{accession}", ext="_clustered.h5ad"),
        raw=config.get_raw_path("{accession}", ext=".h5ad")
    output:
        metrics=config.get_results_path("{accession}", ext="_fidelity.csv")
    resources:
        _resources
    log:
        "results/logs/fidelity_{accession}.log"
    shell:
        """
        python code/fidelity.py \
            --clustered {input.clustered} \
            --raw {input.raw} \
            --output {output.metrics} \
            --log {log}
        """

# --------------------------------------------------------------------------
# Rule: stats
# Performs Fixed-Effects ANOVA or Mixed-Effects modeling
# --------------------------------------------------------------------------
rule stats:
    input:
        geometry=expand(config.get_results_path("{acc}", ext="_geometry.csv"), acc=ACCESSIONS),
        fidelity=expand(config.get_results_path("{acc}", ext="_fidelity.csv"), acc=ACCESSIONS)
    output:
        report=config.get_results_path("statistical_analysis.json"),
        plot=config.get_results_path("statistical_analysis.png")
    resources:
        _resources
    log:
        "results/logs/stats.log"
    shell:
        """
        python code/stats.py \
            --geometry-files {input.geometry} \
            --fidelity-files {input.fidelity} \
            --report {output.report} \
            --plot {output.plot} \
            --log {log}
        """

# --------------------------------------------------------------------------
# Rule: aggregate
# Joins geometry and fidelity metrics for modeling
# --------------------------------------------------------------------------
rule aggregate:
    input:
        geometry=expand(config.get_results_path("{acc}", ext="_geometry.csv"), acc=ACCESSIONS),
        fidelity=expand(config.get_results_path("{acc}", ext="_fidelity.csv"), acc=ACCESSIONS)
    output:
        combined=config.get_results_path("combined_metrics.csv")
    resources:
        _resources
    log:
        "results/logs/aggregate.log"
    shell:
        """
        python code/aggregate.py \
            --geometry-files {input.geometry} \
            --fidelity-files {input.fidelity} \
            --output {output.combined} \
            --log {log}
        """

# --------------------------------------------------------------------------
# Rule: resource_monitor
# Aggregates resource usage logs
# --------------------------------------------------------------------------
rule resource_monitor:
    input:
        logs=expand("results/logs/{step}_{acc}.log", step=["download", "preprocess", "embeddings", "geometry", "cluster", "fidelity"], acc=ACCESSIONS)
    output:
        csv="results/monitoring.csv"
    resources:
        _resources
    shell:
        """
        python code/utils.py --aggregate-monitoring --output {output.csv}
        """

# --------------------------------------------------------------------------
# Default target
# --------------------------------------------------------------------------
rule all:
    input:
        stats=config.get_results_path("statistical_analysis.json"),
        plot=config.get_results_path("statistical_analysis.png"),
        monitoring="results/monitoring.csv"