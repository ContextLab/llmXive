# Rule: stats
rule stats:
    input:
        expand("results/fidelity/{acc}_fidelity.json", acc=get_all_accessions())
    output:
        "results/stats/mixed_effects_results.json"
    message: "Running statistical analysis"
    run:
        from stats import main as stats_main
        stats_main()

# Main entry point
rule all:
    input:
        "results/stats/mixed_effects_results.json"

# Helper function to get all accessions (defined in config)
def get_all_accessions():
    from config import get_all_accessions as cfg_accessions
    return cfg_accessions()