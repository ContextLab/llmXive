[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    data,
    build,
    dist,
    *.egg-info,
    .eggs
per-file-ignores =
    # Allow imports in __init__.py
    */__init__.py: F401
    # Allow print statements in scripts
    code/*.py: T201
    # Allow long lines in data files
    data/*: E501
# Ignore docstring warnings for now (can be enabled later)
ignore = D100,D104,D105
