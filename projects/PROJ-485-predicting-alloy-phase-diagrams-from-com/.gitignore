# Data (Constitution Principle III)
# Exclude all data by default, allow specific project state
data/raw/*
data/processed/*
data/artifacts/*

# State (Constitution Principle V)
# Exclude all state YAMLs EXCEPT the specific project state
state/*.yaml
!state/PROJ-485/*.yaml

