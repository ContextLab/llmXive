[flake8]
max-line-length = 88
extend-ignore = E203, E501, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info,
    .venv,
    venv,
    env
per-file-ignores =
    # Allow unused imports in __init__.py for package exports
    __init__.py:F401
    # Allow magic numbers in tests
    tests/*:S101,PLR2004
# Standard flake8 plugins are expected; additional plugins like flake8-bugbear
# can be added via requirements.txt if desired.
