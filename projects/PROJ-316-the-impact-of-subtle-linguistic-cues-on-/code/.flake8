[flake8]
max-line-length = 88
extend-ignore = E203, E501, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info,
    data,
    figures,
    docs,
    .venv,
    venv
per-file-ignores =
    # Allow unused imports in __init__.py for package exposure
    */__init__.py: F401
    # Allow high line length in test files for readability
    tests/*: E501
