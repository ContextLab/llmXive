{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ResearchClawBench Rubric Schema",
  "description": "Defines the scoring logic for Protocol Alignment and Scientific Core metrics.",
  "type": "object",
  "properties": {
    "metrics": {
      "type": "object",
      "properties": {
        "protocol_alignment": {
          "type": "object",
          "description": "Score (0-50) measuring adherence to procedural steps.",
          "properties": {
            "weight": { "type": "number", "default": 1.0 },
            "criteria": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "step_id": { "type": "string" },
                  "description": { "type": "string" },
                  "points": { "type": "integer" }
                },
                "required": ["step_id", "description", "points"]
              }
            }
          },
          "required": ["weight", "criteria"]
        },
        "scientific_core": {
          "type": "object",
          "description": "Score (0-50) measuring hypothesis quality and reasoning.",
          "properties": {
            "weight": { "type": "number", "default": 1.0 },
            "criteria": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "criterion_id": { "type": "string" },
                  "description": { "type": "string" },
                  "points": { "type": "integer" }
                },
                "required": ["criterion_id", "description", "points"]
              }
            }
          },
          "required": ["weight", "criteria"]
        }
      },
      "required": ["protocol_alignment", "scientific_core"]
    },
    "validation_rules": {
      "type": "object",
      "description": "Rules for contract testing (FR-008).",
      "properties": {
        "set_a_expected": { "type": "string", "description": "Low score expected (scaffold text but no steps)." },
        "set_b_expected": { "type": "string", "description": "High score expected (steps but no scaffold text)." }
      }
    }
  },
  "required": ["metrics", "validation_rules"]
}
