{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Features CSV Schema",
  "description": "Schema for features.csv generated by network_features.py and user_susceptibility.py",
  "type": "object",
  "properties": {
    "columns": {
      "type": "array",
      "items": { "type": "string" },
      "contains": { "const": "cascade_id" },
      "contains": { "const": "node_id" },
      "contains": { "const": "user_id" },
      "contains": { "const": "message_id" },
      "contains": { "const": "platform_id" },
      "contains": { "const": "cascade_size" },
      "contains": { "const": "mean_degree" },
      "contains": { "const": "std_degree" },
      "contains": { "const": "clustering_coeff" },
      "contains": { "const": "mean_betweenness" },
      "contains": { "const": "susceptibility_score" },
      "contains": { "const": "historical_degree" },
      "contains": { "const": "historical_shares" }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "cascade_id": { "type": "string" },
          "node_id": { "type": "string" },
          "user_id": { "type": "string" },
          "message_id": { "type": "string" },
          "platform_id": { "type": "string" },
          "cascade_size": { "type": "integer", "minimum": 1 },
          "mean_degree": { "type": "number" },
          "std_degree": { "type": "number", "minimum": 0 },
          "clustering_coeff": { "type": "number", "minimum": 0, "maximum": 1 },
          "mean_betweenness": { "type": "number", "minimum": 0 },
          "susceptibility_score": { "type": "number", "enum": [0.0, 1.0] },
          "historical_degree": { "type": "integer", "minimum": 0 },
          "historical_shares": { "type": "integer", "minimum": 0 }
        },
        "required": [
          "cascade_id", "node_id", "user_id", "message_id", "platform_id",
          "cascade_size", "mean_degree", "std_degree", "clustering_coeff",
          "mean_betweenness", "susceptibility_score", "historical_degree", "historical_shares"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": ["columns", "rows"]
}