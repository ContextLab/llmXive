[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    build,
    dist,
    .eggs,
    *.egg-info,
    .tox,
    .mypy_cache,
    .pytest_cache,
    data,
    figures,
    state,
    *.pyc,
    .ipynb_checkpoints
per-file-ignores =
    # Ignore unused imports in init files
    code/__init__.py: F401
    tests/__init__.py: F401
    # Allow higher complexity for analysis modules if needed
    code/analysis.py: C901
max-complexity = 15
inline-quotes = double
multiline-quotes = double