[flake8]
max-line-length = 100
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info
per-file-ignores =
    # Allow unused imports in __init__.py for re-exports
    */__init__.py: F401
    # Allow imports in config to be unused if they are just side-effect imports
    code/config.py: F401
