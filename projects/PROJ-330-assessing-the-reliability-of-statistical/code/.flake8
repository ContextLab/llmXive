[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info
per-file-ignores =
    # Allow unused imports in __init__.py if we add one later
    code/src/__init__.py: F401
    # Tests can have longer lines for fixtures sometimes
    code/tests/*: E501
