\newcommand{\firstpagelogos}[3]{%
  \gdef\FirstPageLogoLeft{#1}%
  \gdef\FirstPageLogoRightA{#2}%
  \gdef\FirstPageLogoRightB{#3}%
}

\newcommand{\abstractlogo}[1]{\gdef\AbstractLogoPath{#1}}

\newcommand{\firstpagelogoifexists}[2]{%
  \ifx#1\@empty
  \else
    \IfFileExists{#1}{\includegraphics[height=#2]{#1}}{}%
  \fi
}

\newcommand{\abstractlogoifexists}{%
  \ifx\AbstractLogoPath\@empty
    \firstpagelogoifexists\FirstPageLogoLeft{18pt}%
  \else
    \IfFileExists{\AbstractLogoPath}{\raisebox{-0.18\height}{\includegraphics[height=18pt]{\AbstractLogoPath}}}{}%
  \fi
}

