\def\section{\@startsection {section}{1}{\z@}{3ex plus4pt minus3pt}{5pt}{\headingfont\raggedright}}
\def\subsection{\@startsection{subsection}{2}{\z@}{2.5ex plus3pt minus2pt}{2pt}{\normalsize\bfseries\raggedright}}
\def\subsubsection{\@startsection{subsubsection}{3}{\z@}{2ex plus2.5pt minus1.5pt}{2pt}{\normalsize\bfseries\itshape\raggedright}}
\def\paragraph{\@startsection{paragraph}{4}{\z@}{1.5ex plus
   0.5ex minus .2ex}{-1em}{\normalsize\bfseries}}
\def\subparagraph{\@startsection{subparagraph}{5}{\parindent}{1.5ex plus
   0.5ex minus .2ex}{-1em}{\normalsize\bfseries}}

