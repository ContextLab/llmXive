{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://llmxive.org/schemas/regression_result.json",
  "title": "RegressionResult",
  "description": "Schema for the result of regressing scaling exponents against structural metrics or topology.",
  "type": "object",
  "required": [
    "regression_id",
    "model_type",
    "formula",
    "coefficients",
    "statistics",
    "timestamp"
  ],
  "properties": {
    "regression_id": {
      "type": "string",
      "description": "Unique identifier for this regression analysis."
    },
    "model_type": {
      "type": "string",
      "enum": ["ModelA_TopologyOnly", "ModelB_StructuralWithinTopology"],
      "description": "Type of regression model executed."
    },
    "formula": {
      "type": "string",
      "description": "String representation of the regression formula (e.g., 'gamma ~ Topology')."
    },
    "coefficients": {
      "type": "object",
      "description": "Mapping of predictor variable names to their estimated coefficients.",
      "additionalProperties": {
        "type": "number"
      }
    },
    "statistics": {
      "type": "object",
      "description": "Overall regression statistics.",
      "required": ["r_squared", "adj_r_squared", "f_statistic", "p_value"],
      "properties": {
        "r_squared": {
          "type": "number",
          "description": "R-squared value."
        },
        "adj_r_squared": {
          "type": "number",
          "description": "Adjusted R-squared value."
        },
        "f_statistic": {
          "type": "number",
          "description": "F-statistic for the model."
        },
        "p_value": {
          "type": "number",
          "description": "P-value for the F-statistic."
        }
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of analysis completion."
    }
  },
  "additionalProperties": false
}