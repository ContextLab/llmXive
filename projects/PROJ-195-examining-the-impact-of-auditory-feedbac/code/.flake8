[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    .venv,
    build,
    dist,
    .eggs,
    *.egg-info
per-file-ignores =
    # Allow unused imports in __init__.py for package exports
    */__init__.py: F401
    # Allow missing docstrings in test files
    tests/*: D100,D101,D102,D103
