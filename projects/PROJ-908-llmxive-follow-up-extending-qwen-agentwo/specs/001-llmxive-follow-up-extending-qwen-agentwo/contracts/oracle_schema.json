{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ground Truth Oracle Schema",
  "description": "Schema for the deterministic state-transition oracle derived from Qwen-AgentWorld source code.",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "version": { "type": "string", "description": "Schema version" },
        "source": { "type": "string", "description": "Source code repository or file path" },
        "generated_at": { "type": "string", "format": "date-time" },
        "checksum": { "type": "string", "description": "SHA-256 of the source logic" }
      },
      "required": ["version", "source", "generated_at"]
    },
    "states": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Unique state identifier" },
          "type": { "type": "string", "enum": ["spatial", "temporal", "causal", "object_state"] },
          "attributes": {
            "type": "object",
            "additionalProperties": true,
            "description": "Key-value pairs describing the state"
          }
        },
        "required": ["id", "type", "attributes"]
      }
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "source_state_id": { "type": "string", "description": "Reference to states[].id" },
          "target_state_id": { "type": "string", "description": "Reference to states[].id" },
          "action": { "type": "string", "description": "The action triggering the transition" },
          "conditions": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Logical conditions (FOL strings) required for transition"
          },
          "effects": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Logical effects (FOL strings) resulting from transition"
          }
        },
        "required": ["id", "source_state_id", "target_state_id", "action"]
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "logic": { "type": "string", "description": "Prolog or FOL representation" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "required": ["id", "logic"]
      }
    }
  },
  "required": ["metadata", "states", "transitions"]
}
