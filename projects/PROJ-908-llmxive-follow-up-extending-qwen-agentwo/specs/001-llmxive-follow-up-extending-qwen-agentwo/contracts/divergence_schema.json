{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Divergence Report Schema",
  "description": "Schema for the divergence analysis report comparing LLM, Extracted Rules, and Oracle.",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "analysis_date": { "type": "string", "format": "date-time" },
        "oracle_version": { "type": "string" },
        "rules_version": { "type": "string" },
        "task_set": { "type": "string" }
      },
      "required": ["version", "analysis_date", "oracle_version", "rules_version"]
    },
    "counts": {
      "type": "object",
      "properties": {
        "total_transitions": { "type": "integer" },
        "match": { "type": "integer", "description": "LLM == Oracle" },
        "hallucination": { "type": "integer", "description": "LLM != Oracle AND Rule Inferable" },
        "rule_gap": { "type": "integer", "description": "LLM != Oracle AND Rule Inferable BUT LLM failed" },
        "extraction_uncertainty": { "type": "integer", "description": "Ambiguous/contradictory traces (excluded from primary metrics)" },
        "coverage_gap": { "type": "integer", "description": "Cold start: No rule exists for the state (excluded)" }
      },
      "required": ["total_transitions", "match", "hallucination", "rule_gap"]
    },
    "excluded_metrics": {
      "type": "object",
      "properties": {
        "extraction_uncertainty": { "type": "integer" },
        "cold_start": { "type": "integer" }
      },
      "description": "Counts of transitions excluded from primary Hallucination/Rule Gap calculations"
    },
    "statistical_analysis": {
      "type": "object",
      "properties": {
        "adherence_boundary": {
          "type": "object",
          "properties": {
            "step_count": { "type": "integer", "description": "Step count where adherence drops below 95%" },
            "complexity_threshold": { "type": "number", "description": "State complexity threshold" }
          }
        },
        "correlation": {
          "type": "object",
          "properties": {
            "pearson_r": { "type": "number", "description": "Correlation between rule precision and CoT quality" },
            "p_value": { "type": "number" },
            "significance": { "type": "boolean", "description": "p <= 0.05" }
          }
        },
        "permutation_test": {
          "type": "object",
          "properties": {
            "p_value": { "type": "number" },
            "significant": { "type": "boolean" }
          }
        }
      }
    },
    "classified_transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "transition_id": { "type": "string" },
          "llm_action": { "type": "string" },
          "oracle_action": { "type": "string" },
          "classification": {
            "type": "string",
            "enum": ["match", "hallucination", "rule_gap", "extraction_uncertainty", "coverage_gap"]
          },
          "reasoning": { "type": "string" }
        },
        "required": ["transition_id", "classification"]
      }
    }
  },
  "required": ["metadata", "counts", "excluded_metrics"]
}