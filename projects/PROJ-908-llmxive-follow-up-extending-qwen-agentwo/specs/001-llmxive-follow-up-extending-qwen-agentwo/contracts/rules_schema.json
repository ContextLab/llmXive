{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "specs/001-llmxive-followup/contracts/rules_schema.json",
  "title": "Extracted Rules Schema",
  "description": "Schema for the hypothesis rule set extracted from LLM CoT traces via ILP/Decision Tree.",
  "type": "object",
  "required": ["version", "metadata", "rules"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version identifier",
      "const": "1.0.0"
    },
    "metadata": {
      "type": "object",
      "required": ["extraction_method", "generated_at", "trace_source"],
      "properties": {
        "extraction_method": {
          "type": "string",
          "description": "Method used for extraction (e.g., 'ILP', 'DecisionTree', 'PrologInduction')"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of extraction"
        },
        "trace_source": {
          "type": "string",
          "description": "Path or identifier of the CoT traces used"
        },
        "confidence_threshold": {
          "type": "number",
          "description": "Minimum confidence score required to include a rule"
        }
      }
    },
    "rules": {
      "type": "array",
      "description": "List of extracted logical rules",
      "items": {
        "type": "object",
        "required": ["id", "logic", "confidence", "support"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the rule"
          },
          "logic": {
            "type": "string",
            "description": "The logical representation of the rule (e.g., Prolog clause, Python boolean expression)"
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Statistical confidence of the rule based on trace frequency"
          },
          "support": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of traces supporting this rule"
          },
          "category": {
            "type": "string",
            "enum": ["spatial", "temporal", "causal", "resource", "unknown"],
            "description": "Semantic category of the rule"
          },
          "uncertainty_flag": {
            "type": "boolean",
            "default": false,
            "description": "True if the rule is ambiguous or derived from conflicting traces"
          },
          "source_traces": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IDs of trace samples that contributed to this rule"
          }
        }
      }
    },
    "statistics": {
      "type": "object",
      "properties": {
        "total_rules": {
          "type": "integer"
        },
        "ambiguous_count": {
          "type": "integer"
        },
        "average_confidence": {
          "type": "number"
        }
      }
    }
  }
}
