{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Extracted Rules Schema",
  "description": "Schema for the hypothesized rule set extracted from LLM CoT traces using ILP/Decision Trees.",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "extraction_method": { "type": "string", "description": "e.g., 'ILP', 'DecisionTree', 'PrologInduction'" },
        "trace_source": { "type": "string", "description": "Path to CoT traces used" },
        "generated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["version", "extraction_method", "trace_source", "generated_at"]
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "head": { "type": "string", "description": "The conclusion predicate" },
          "body": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of premise predicates"
          },
          "logic_form": { "type": "string", "description": "Full FOL or Prolog clause string" },
          "support_count": { "type": "integer", "minimum": 0, "description": "Number of traces supporting this rule" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "status": { "type": "string", "enum": ["verified", "contradicted", "uncertain"], "description": "Validation status against Oracle" }
        },
        "required": ["id", "head", "body", "logic_form", "support_count"]
      }
    },
    "uncertainty_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "trace_id": { "type": "string" },
          "reason": { "type": "string", "enum": ["ambiguous", "contradictory", "insufficient_data"] },
          "excluded_from_metrics": { "type": "boolean", "default": true }
        },
        "required": ["trace_id", "reason"]
      }
    }
  },
  "required": ["metadata", "rules"]
}
