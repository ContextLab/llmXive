# Project specific data directories (raw and processed data are tracked via .gitattributes or LFS if needed, but directories themselves are ignored by default here to prevent accidental commits of large files)
# Note: We explicitly track the directory structure but ignore contents unless .gitkeep is used or LFS is configured.
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/temp/
data/cache/

# Logs
*.log
logs/

# Test/Coverage
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# Secrets
.env
*.pem
*.key
