[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist
per-file-ignores =
    # Allow unused imports in __init__.py for exposing public API
    */__init__.py: F401
    # Allow unused variables in analysis scripts (often intermediate results)
    code/data/analysis.py: F841
    code/data/descriptors.py: F841
