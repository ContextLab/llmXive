[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info
per-file-ignores =
    # Allow unused imports in __init__.py
    */__init__.py:F401
    # Allow assert statements in tests
    tests/*:S101
max-complexity = 15
