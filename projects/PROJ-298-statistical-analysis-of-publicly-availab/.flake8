[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info,
    notebooks,
    .ipynb_checkpoints
per-file-ignores =
    # Allow imports in __init__.py
    */__init__.py: F401
    # Allow unused imports in analysis modules if they are part of the API surface
    code/analysis/*.py: F401
    # Allow long lines in data files if needed
    data/*.json: E501
