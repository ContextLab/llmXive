[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    .venv,
    build,
    dist,
    .eggs,
    *.egg-info
per-file-ignores =
    # Allow unused imports in __init__.py for API surface exposure
    */__init__.py: F401
    # Allow imports in test files for setup
    tests/*: F401
max-complexity = 15