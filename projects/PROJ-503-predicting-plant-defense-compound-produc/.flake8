[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info,
    venv,
    .venv
per-file-ignores =
    # Allow unused imports in __init__.py files
    */__init__.py: F401
    # Allow long lines in docstrings
    code/models/*.py: E501
max-complexity = 15
