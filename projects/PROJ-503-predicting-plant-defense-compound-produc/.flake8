[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info
per-file-ignores =
    # Allow unused imports in __init__.py for API surface exposure
    */__init__.py: F401
# Additional flake8 settings for scientific code
# Ignore line-too-long for docstrings and URLs
max-complexity = 15
