[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    .eggs,
    *.egg-info
per-file-ignores =
    # Allow unused imports in __init__.py files
    */__init__.py:F401
    # Allow high complexity in main orchestrator if necessary (tune as needed)
    code/main.py:C901
