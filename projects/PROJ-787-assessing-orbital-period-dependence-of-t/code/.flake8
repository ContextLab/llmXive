[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude = 
    .git,
    __pycache__,
    .eggs,
    *.egg-info,
    build,
    dist
per-file-ignores =
    # Allow unused imports in __init__.py for exposing public API
    */__init__.py: F401
    # Allow unused arguments in tests
    tests/*: F841
ignore = E203, W503
