[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    .venv,
    build,
    dist,
    *.egg-info
per-file-ignores =
    # Allow unused imports in __init__.py if needed later
    **/__init__.py: F401
    # Allow docstrings in tests
    tests/**/*.py: D100, D101, D102, D103
