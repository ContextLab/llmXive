# Data artifacts (large files, binary formats)
data/

# Python bytecode and cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Environment and secrets
.env
.env.local
.env.*.local

# Project state (exclude specific keep files)
state/projects/*.yaml
!state/projects/.gitkeep

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db

# Logs and temporary files
*.log
tmp/
temp/