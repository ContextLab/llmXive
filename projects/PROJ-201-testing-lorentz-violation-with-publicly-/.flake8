[flake8]
max-line-length = 88
extend-ignore = E203, E501, W503
exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    build,
    dist,
    *.egg-info
per-file-ignores =
    # Allow imports in __init__.py
    */__init__.py: F401
    # Allow unused variables in tests (often used for side effects)
    tests/*: F841
