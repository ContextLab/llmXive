[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info,
    data,
    .venv,
    venv
per-file-ignores =
    # Allow unused imports in __init__.py for namespace exposure
    */__init__.py: F401
    # Allow docstrings-only test placeholders
    tests/unit/test_*.py: D100,D101,D102
