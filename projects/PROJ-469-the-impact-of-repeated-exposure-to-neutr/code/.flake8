[flake8]
max-line-length = 100
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info,
    data/,
    results/,
    logs/
per-file-ignores =
    # Allow imports in __init__ files if they exist
    */__init__.py:F401
    # Allow unused variables in stubs or specific test files if needed
    tests/*:F841
