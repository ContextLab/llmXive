# Python compiled artifacts
*.pyc
*.pyo
*.pyd
__pycache__/
*.egg-info/
*.egg
dist/
build/

# Virtual environments
venv/
.venv/
env/
.env/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS-specific files
.DS_Store
Thumbs.db

# Log files (except ELBO logs which are needed for reproducibility)
*.log
!logs/elbo/

# Data files (raw and processed - should be downloaded separately)
data/raw/*.csv
data/raw/*.json
data/processed/*.csv
data/processed/*.json

# Test coverage and profiling
.coverage
coverage/
htmlcov/
*.prof
*.profraw

# Jupyter notebooks cache
.ipynb_checkpoints/

# State files with checksums (can be regenerated)
state/projects/*.yaml

# Temporary files
*.tmp
*.temp
.tmp/

# Model checkpoints and large artifacts
checkpoints/
models/*.pth
models/*.pt
models/*.h5

# Configuration overrides
config.local.yaml
.env.local

# Scripts output logs
code/.tasks/
code/scripts/*.log
