[flake8]
# Linting configuration for llmXive project
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info
per-file-ignores =
    # Allow imports in __init__.py files
    */__init__.py: F401
    # Allow unused variables in tests
    tests/*: F841
