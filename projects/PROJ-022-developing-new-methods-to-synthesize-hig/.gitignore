# Data directories - ignore all contents
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/reports/*
!data/reports/.gitkeep

# Model artifacts
*.pkl
*.joblib
*.pth
*.onnx

# Python cache and temporary files
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Logs
*.log
logs/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Virtual environments
venv/
.venv/
env/
.env/

# Jupyter notebooks
.ipynb_checkpoints/

# Temporary files
tmp/
temp/
*.tmp
