# Research project specific
# Raw data (should not be tracked - large files)
data/raw/*.csv
data/raw/*.json
data/raw/*.parquet
data/raw/*.zip
data/raw/*.gz

# Processed data (can be regenerated)
data/processed/*.csv
data/processed/*.json

# Output files (generated artifacts)
data/output/*.json
data/output/*.csv
figures/*.png
figures/*.pdf
figures/*.svg

