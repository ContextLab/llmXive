\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{microsoft-tech-report}[2026/04/24 ZIP Lab technical report style]

% --------------------------------------------------
% Packages
% --------------------------------------------------
\RequirePackage[a4paper,top=2.2cm,bottom=2.4cm,left=2.4cm,right=2.4cm,headheight=14pt,headsep=16pt,footskip=26pt]{geometry}
\RequirePackage[T1]{fontenc}
\RequirePackage{lmodern}
\RequirePackage{microtype}
\RequirePackage{placeins}
\RequirePackage{hyphenat}
\RequirePackage{setspace}
\RequirePackage[table]{xcolor}
\RequirePackage{tgheros}
\RequirePackage[most]{tcolorbox}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}
\RequirePackage{caption}
\RequirePackage[numbers,sort&compress]{natbib}
\RequirePackage{graphicx}

% --------------------------------------------------
% Color System (MODERN + CLEAN)
% --------------------------------------------------
\definecolor{microsoftblue}{HTML}{2563EB}     % primary (modern blue)
\definecolor{microsoftaccent}{HTML}{F59E0B}   % accent (orange highlight)
\definecolor{microsoftdark}{HTML}{0F172A}     % main text (deep slate)
\definecolor{microsoftgray}{HTML}{475569}     % secondary text
\definecolor{microsoftline}{HTML}{CBD5E1}     % divider
\definecolor{microsoftcard}{HTML}{F1F5F9}     % light background

% --------------------------------------------------
% Meta
% --------------------------------------------------
\newcommand{\microsoftreportlabel}{ZIP Lab}
\newcommand{\microsoftreportshorttitle}{}
\newcommand{\techreportlabel}[1]{\renewcommand{\microsoftreportlabel}{#1}}
\newcommand{\techreportshorttitle}[1]{\renewcommand{\microsoftreportshorttitle}{#1}}

% --------------------------------------------------
% Typography
% --------------------------------------------------
\newcommand{\microsoftsans}{\fontfamily{qhv}\selectfont}
\newcommand{\microsofttitlefont}{\microsoftsans\bfseries}
\newcommand{\microsoftdatefont}{\rmfamily\itshape}

\newcommand{\microsoftmetalabel}[1]{{\microsoftsans\small\bfseries\color{microsoftblue} #1:}\hspace{0.35em}}

\newcommand{\microsoftbrandmark}{}

% --------------------------------------------------
% Paragraph & spacing
% --------------------------------------------------
\setlength{\parindent}{1em}
\setlength{\parskip}{0pt}
\linespread{1.05} % 更舒服

% --------------------------------------------------
% Caption Style
% --------------------------------------------------
\DeclareCaptionLabelSeparator{custom}{}
\DeclareCaptionFormat{custom}{{\microsoftsans\textbf{#1 #2}} #3}
\captionsetup{
  singlelinecheck=false,
  format=custom,
  labelsep=custom,
  font=small
}

% --------------------------------------------------
% Section Style (More hierarchy)
% --------------------------------------------------
\titleformat*{\section}{\Large\microsoftsans\bfseries\color{microsoftdark}}
\titleformat*{\subsection}{\large\microsoftsans\bfseries\color{microsoftdark}}
\titleformat*{\subsubsection}{\normalsize\microsoftsans\bfseries\color{microsoftdark}}

\titlespacing*{\section}{0pt}{1.2em}{0.6em}
\titlespacing*{\subsection}{0pt}{0.9em}{0.4em}

% --------------------------------------------------
% Abstract
% --------------------------------------------------
\renewenvironment{abstract}
  {%
    \par\noindent
    \small
    \color{microsoftdark}
  }
  {%
    \par\normalsize
  }

% --------------------------------------------------
% Header / Footer
% --------------------------------------------------
\fancypagestyle{firstheader}{
  \fancyhf{}
  \fancyhead[L]{\footnotesize\microsoftsans\color{microsoftgray}\microsoftreportlabel}
  \fancyhead[R]{\microsoftbrandmark}
  \renewcommand{\headrulewidth}{0.8pt}
  \renewcommand{\headrule}{\hbox to\headwidth{\color{microsoftline}\leaders\hrule height \headrulewidth\hfill}}
}

\pagestyle{fancy}
\fancyhf{}
\fancyfoot[C]{\footnotesize\microsoftsans\color{microsoftgray}\thepage}
\renewcommand{\headrulewidth}{0pt}

% --------------------------------------------------
% Title Box (KEY VISUAL UPGRADE)
% --------------------------------------------------
\newtcolorbox{microsofttitlebox}{
  enhanced,
  frame hidden,
  colback=microsoftcard,
  colframe=microsoftline,
  boxrule=0.5pt,
  arc=8pt,
  left=0.34cm,
  right=0.34cm,
  top=0.28cm,
  bottom=0.28cm,
  before skip=0pt,
  after skip=1.0em,
  drop shadow={opacity=0.06}
}

% --------------------------------------------------
% Highlight command (NEW)
% --------------------------------------------------
\newcommand{\highlight}[1]{\textcolor{microsoftaccent}{\textbf{#1}}}

% --------------------------------------------------
% Subtle divider
% --------------------------------------------------
\newcommand{\microsoftdivider}{
  \vspace{0.6em}
  {\color{microsoftline}\hrule height 0.6pt}
  \vspace{0.6em}
}
