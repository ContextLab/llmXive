[flake8]
max-line-length = 88
extend-ignore = E203, E266, W503
exclude = .git,__pycache__,venv,build,dist,.eggs,*.egg-info
per-file-ignores =
    # Allow unused imports in __init__.py for public API exposure
    */__init__.py:F401
    # Allow docstrings to be missing in tests
    tests/*:D100,D101,D102,D103
# Enable flake8-docstrings if installed, otherwise ignore
# ignore = E121,E123,E126,E226,E24,E704,W503,W504
