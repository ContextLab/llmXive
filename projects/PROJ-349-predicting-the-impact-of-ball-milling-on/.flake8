[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info,
    venv,
    .venv,
    data
per-file-ignores =
    # Allow wildcard imports for __init__.py files
    */__init__.py: F401
    # Allow unused imports in test files for fixtures
    tests/*: F401
max-complexity = 10
inline-quotes = double
multiline-quotes = double
docstring-quotes = double
count = True
statistics = True
show-source = True
