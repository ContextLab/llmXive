{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://llmxive.org/schemas/model_performance_record.schema.json",
  "title": "Model Performance Record",
  "description": "Schema for model evaluation metrics and performance records per Constitution IV traceability requirements",
  "type": "object",
  "required": [
    "model_type",
    "roc_auc",
    "precision",
    "recall",
    "std_dev",
    "data_row_id",
    "code_block_id"
  ],
  "properties": {
    "model_type": {
      "type": "string",
      "description": "Type of machine learning model used",
      "enum": ["RandomForest", "GradientBoosting", "LogisticRegression", "SVM", "NeuralNetwork"]
    },
    "roc_auc": {
      "type": "number",
      "description": "Area Under the Receiver Operating Characteristic Curve",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "precision": {
      "type": "number",
      "description": "Precision metric (positive predictive value)",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "recall": {
      "type": "number",
      "description": "Recall metric (true positive rate)",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "f1_score": {
      "type": ["number", "null"],
      "description": "F1 harmonic mean of precision and recall",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "std_dev": {
      "type": "number",
      "description": "Standard deviation across cross-validation folds",
      "minimum": 0.0
    },
    "data_row_id": {
      "type": "string",
      "description": "UUID linking to exactly one row in source data file per Constitution IV",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "code_block_id": {
      "type": "string",
      "description": "Identifier referencing the generating script block per Constitution IV traceability"
    },
    "training_time": {
      "type": "number",
      "description": "Training time in seconds",
      "minimum": 0.0
    },
    "validation_limitation_note": {
      "type": ["string", "null"],
      "description": "Notes on validation limitations per Constitution VII"
    },
    "cross_validation_folds": {
      "type": "integer",
      "description": "Number of CV folds used",
      "minimum": 2
    },
    "hyperparameters": {
      "type": "object",
      "description": "Model hyperparameters used for this evaluation"
    },
    "dataset_split": {
      "type": "object",
      "description": "Dataset split information",
      "properties": {
        "train_size": {
          "type": "integer",
          "minimum": 1
        },
        "test_size": {
          "type": "integer",
          "minimum": 1
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of evaluation",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}