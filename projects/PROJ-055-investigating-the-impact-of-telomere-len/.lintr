# R linting configuration (lintr)
linters:
  - line_length_linter(88)
  - object_name_linter()
  - assignment_linter()
  - trailing_whitespace_linter()
  - braces_linter()
  - comma_linter()
  - function_left_parentheses_linter()
  - invisible_linter()
  - pipe_continuation_linter()
  - spaces_inside_linter()
  - spaces_left_parentheses_linter()
  - T_and_F_symbol_linter()
  - whitespace_linter()
  - unnecessary_nested_if_linter()
  - equals_na_linter()
  - object_usage_linter()
  - library_call_linter()
  - comment_linter()
