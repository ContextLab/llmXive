# R Linter configuration
linters:
  - line_length_linter(length = 120)
  - object_name_linter()
  - assignment_linter()
  - trailing_whitespace_linter()
  - paren_body_linter()
  - unnecessary_concatenation_linter(allow_single_expression = TRUE)
  - commented_code_linter()
  - object_usage_linter()
  - library_call_linter()
  - numeric_leading_zero_linter()
  - spaces_left_parentheses_linter()
  - spaces_inside_linter()
  - closing_brace_linter()
  - commafy_linter()
  - redundant_ifelse_linter()
  - seq_linter()
  - single_quotes_linter()
  - spaces_left_brackets_linter()
  - spaces_right_brackets_linter()
  - whitespace_linter()
  - no_tab_linter()
  - no_bare_trailing_whitespace_linter()
  - object_length_linter(license = FALSE)
  - paren_body_linter()
  - implicit_integer_linter()
  - infix_spaces_linter()
  - nonportable_path_linter()
  - pipe_continuation_linter()
  - duplicate_argument_linter()
  - fixed_regex_linter()
  - namespace_linter()
  - unneeded_concatenation_linter()
  - unnecessary_nested_if_linter()
  - unnecessary_lambda_linter()
  - unused_import_linter()
  - use_pipe_linter()
  - vector_logic_linter()
  - yoda_test_linter()
