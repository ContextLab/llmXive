[MAIN]
jobs=0
persistent=yes
extension-pkg-whitelist=
    numpy,
    pandas,
    scipy,
    statsmodels

[MESSAGES CONTROL]
disable=
    C0114,  # missing-module-docstring
    C0115,  # missing-class-docstring
    C0116,  # missing-function-docstring
    R0903,  # too-few-public-methods
    R0913,  # too-many-arguments
    R0914,  # too-many-locals
    W0511,  # fixme
    W1203,  # logging-fstring-interpolation (we use f-strings for formatting)
    E1136,  # unsubscriptable-object (pandas/numpy sometimes trigger this falsely)
    R0917,  # too-many-positional-arguments

[FORMAT]
max-line-length=88
max-module-lines=2000
single-line-class-stmt=no
single-line-if-stmt=no

[BASIC]
good-names=
    i, j, k,
    id,
    df,
    ts,
    x, y, z,
    r, p,
    n, m,
    k,
    cfg,
    src, dst,
    idx,
    _

[DESIGN]
max-args=10
max-locals=25
max-returns=6
max-branches=15
max-statements=75
max-attributes=15
max-public-methods=30

[SIMILARITIES]
min-similarity-lines=6
ignore-comments=yes
ignore-docstrings=yes

[VARIABLES]
init-import=no
dummy-variables-rgx=_+$|dummy
additional-builtins=

[TYPECHECK]
ignored-classes=
    numpy.ndarray,
    pandas.DataFrame,
    pandas.Series
