[flake8]
max-line-length = 88
extend-ignore = E203, E501, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info,
    .venv,
    venv,
    env
per-file-ignores =
    # Ignore unused imports in __init__.py files
    */__init__.py: F401
    # Allow higher complexity in analysis modules if needed
    code/analysis.py: C901
max-complexity = 15
