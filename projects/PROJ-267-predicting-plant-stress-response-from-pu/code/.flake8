[flake8]
max-line-length = 88
extend-ignore = E203, E501, W503
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    build,
    dist,
    .eggs,
    *.egg-info,
    data,
    results,
    logs
per-file-ignores =
    # Allow unused imports in __init__.py for API exposure
    code/__init__.py: F401
    tests/__init__.py: F401
