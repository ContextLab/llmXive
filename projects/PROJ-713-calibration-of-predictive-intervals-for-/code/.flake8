[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    .eggs,
    *.egg-info,
per-file-ignores =
    # Allow unused imports in __init__.py for public API re-exports
    */__init__.py: F401
    # Allow F401 in tests for imported fixtures
    tests/*: F401
ignore =
    E203,
    W503
