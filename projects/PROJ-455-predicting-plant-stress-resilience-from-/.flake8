[flake8]
max-line-length = 88
extend-ignore = E203, E501, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info
per-file-ignores =
    # Allow unused imports in __init__.py for public API exposure
    */__init__.py: F401
    # Allow unused arguments in tests
    tests/*: ARG001, ANN001, ANN201
