# Data directories (raw, derived, artifacts) - ignored to keep repo clean
# These contain large files generated during pipeline execution
data/raw/
data/derived/
data/artifacts/

# Keep data/ directory itself but ignore contents of subdirectories
data/*
!data/.gitkeep
!data/raw/.gitkeep
!data/derived/.gitkeep
!data/artifacts/.gitkeep

# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary files
*.tmp
.tmp/

# Jupyter notebooks cache
.ipynb_checkpoints/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Build artifacts
dist/
build/
*.egg-info/

# Environment variables (if any)
.env
.env.local