[flake8]
max-line-length = 88
extend-ignore = E203, E501, W503
exclude =
    .git,
    __pycache__,
    .eggs,
    *.egg-info,
    build,
    dist,
    .venv,
    venv,
per-file-ignores =
    # Allow unused imports in __init__.py if any
    __init__.py: F401
    # Allow magic numbers in test files
    tests/*: W503
# Ignore specific flake8 warnings common in scientific code
ignore = E203, E501, W503
