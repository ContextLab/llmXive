[MAIN]
ignore=CVS,venv,.venv,build,dist,.eggs
jobs=1
persistent=yes
extension-pkg-allow-list=pandas,numpy,pymatgen

[MESSAGES CONTROL]
disable=
    C0114,
    C0115,
    C0116,
    R0903,
    R0913,
    R0914,
    W0511,
    W1203,
    R0801,
    R0917,
    R0902,
    R0904,
    R0912,
    R0915,
    W0613,
    W0621,
    R0911,
    R0912,
    R0914,
    R0915,
    C0301,
    C0325,
    C0330,
    R0903,
    R0913,
    R0914,
    W0511,
    W1203,
    R0801,
    R0917,
    R0902,
    R0904,
    R0912,
    R0915,
    W0613,
    W0621,
    R0911,
    R0912,
    R0914,
    R0915

[FORMAT]
expected-line-ending-format=LF
max-line-length=88

[BASIC]
good-names=i,j,k,v,ex,_,f,fd,df

[DESIGN]
max-args=10
max-locals=15
max-returns=6
max-branches=12
max-statements=50
max-attributes=10
max-public-methods=20
