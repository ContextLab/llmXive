[flake8]
max-line-length = 88
extend-ignore = E203, E501, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info,
    venv,
    .venv
per-file-ignores =
    # Allow unused imports in __init__.py for public API exposure
    */__init__.py: F401
    # Allow long lines in docstrings or data-heavy lines if necessary
    */data_ingestion.py: E501
