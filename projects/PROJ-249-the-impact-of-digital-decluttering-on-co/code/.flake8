[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info,
    data,
    results,
    figures,
    .pytest_cache
per-file-ignores =
    # Allow unused imports in __init__.py for public API exposure
    */__init__.py: F401
