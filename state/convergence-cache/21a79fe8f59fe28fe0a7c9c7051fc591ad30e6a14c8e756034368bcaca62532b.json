{"_ts": 1782362344.0828276, "concerns": [{"id": "requirements_coverage-a8f69eec", "reviewer": "requirements_coverage", "severity": "requirement", "artifact": "projects/PROJ-492-evaluating-the-statistical-validity-of-p/specs/001-evaluating-the-statistical-validity-of-p/spec.md", "location": "spec.md:User Story 3 \u2013 Reproducibility Package Export", "text": "User Story\u202f3 is not anchored to any functional requirement or success criterion; no FR explicitly mandates the export of a reproducible package and no SC measures its correctness.", "round": 1}, {"id": "requirements_coverage-102ce82c", "reviewer": "requirements_coverage", "severity": "requirement", "artifact": "projects/PROJ-492-evaluating-the-statistical-validity-of-p/specs/001-evaluating-the-statistical-validity-of-p/spec.md", "location": "spec.md:User Story 4 \u2013 Efficient CI Execution", "text": "User Story\u202f4 lacks an explicit anchor to a functional requirement or success criterion; although FR\u2011009 describes CPU\u2011only execution, the story does not reference it.", "round": 1}, {"id": "requirements_coverage-69e4c0dc", "reviewer": "requirements_coverage", "severity": "requirement", "artifact": "projects/PROJ-492-evaluating-the-statistical-validity-of-p/specs/001-evaluating-the-statistical-validity-of-p/spec.md", "location": "spec.md:Functional Requirements FR-001", "text": "FR\u2011001 (accept list of URLs) is not linked to any user story; no story cites FR\u2011001.", "round": 1}, {"id": "requirements_coverage-e6bd746e", "reviewer": "requirements_coverage", "severity": "requirement", "artifact": "projects/PROJ-492-evaluating-the-statistical-validity-of-p/specs/001-evaluating-the-statistical-validity-of-p/spec.md", "location": "spec.md:Functional Requirements FR-002", "text": "FR\u2011002 (automatic extraction) is orphaned; no user story references FR\u2011002.", "round": 1}, {"id": "requirements_coverage-8342570d", "reviewer": "requirements_coverage", "severity": "requirement", "artifact"